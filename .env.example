# AI Studio runtime configuration
AI_STUDIO_APP_NAME=AI Studio
AI_STUDIO_API_V1_PREFIX=/api/v1
AI_STUDIO_ENVIRONMENT=local
AI_STUDIO_DEBUG=false
AI_STUDIO_LOG_LEVEL=INFO
AI_STUDIO_MAX_FILE_SIZE_BYTES=10485760
AI_STUDIO_UPLOAD_DIR=../data/uploads
AI_STUDIO_OUTPUT_DIR=../data/outputs
AI_STUDIO_MOCK_EXECUTOR_DELAY_SECONDS=2
AI_STUDIO_DEFAULT_IMAGE_MODEL=sd15
AI_STUDIO_SD15_CHECKPOINT=v1-5-pruned-emaonly-fp16.safetensors
AI_STUDIO_SDXL_LIGHTNING_CHECKPOINT=sdxl_lightning_4step.safetensors
AI_STUDIO_RUNTIME_GPU_NAME=Apple Silicon MPS

# Persistence
AI_STUDIO_HISTORY_BACKEND=sqlite
AI_STUDIO_DATABASE_URL=sqlite:///../data/ai_studio.db

# FaceFusion CLI integration
AI_STUDIO_FACEFUSION_PROJECT_PATH=../FaceFusion/facefusion
AI_STUDIO_FACEFUSION_PYTHON_PATH=python
AI_STUDIO_FACEFUSION_EXECUTION_PROVIDER=cpu
AI_STUDIO_FACEFUSION_DEVICE_ID=0
AI_STUDIO_FACEFUSION_TIMEOUT_SECONDS=300

# ComfyUI integration
COMFYUI_BASE_URL=http://127.0.0.1:8188
AI_STUDIO_COMFYUI_TIMEOUT_SECONDS=120

# LLM Gateway
AI_STUDIO_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/v3
AI_STUDIO_LLM_API_KEY=replace-with-your-api-key
AI_STUDIO_LLM_DEFAULT_MODEL=replace-with-your-endpoint-id
AI_STUDIO_LLM_TIMEOUT_SECONDS=60
AI_STUDIO_LLM_MAX_CONTEXT_MESSAGES=20
